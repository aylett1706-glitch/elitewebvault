{
  "name": "GameProgress",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "game_id": {
      "type": "string"
    },
    "game_title": {
      "type": "string"
    },
    "progress_label": {
      "type": "string"
    },
    "session_seconds": {
      "type": "number",
      "default": 0
    },
    "last_played": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "user_email",
    "game_id"
  ]
}